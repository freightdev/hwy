# HWY local development configuration only.
# Copy to configs/env/hwy.dev.env or run: python3 scripts/generate_dev_env.py
# Do not use for production. Do not commit real secrets.

ENVIRONMENT=development

# URLs
BACKEND_API_URL=http://localhost:18000
VITE_API_BASE_URL=http://localhost:18000/api/v1
VITE_LOCAL_API_BASE_URL=http://localhost:18000/api/v1
VITE_PUBLIC_API_BASE_URL=https://api.hwytms.com/api/v1
FRONTEND_URL=http://localhost:5173
BACKEND_PORT=18000
CODRIVER_RUNTIME_URL=http://localhost:8010
CODRIVER_INTERNAL_URL=http://codriver:8010

# Database
POSTGRES_DB=hwytms
POSTGRES_USER=hwy
POSTGRES_PASSWORD=hwy
POSTGRES_PORT=55432
DATABASE_URL=postgresql://hwy:hwy@db:5432/hwytms
BACKEND_DATABASE_URL=postgresql://hwy:hwy@db:5432/hwytms

# CORS
CORS_ORIGIN=http://localhost:5173,http://frontend:5173,http://localhost:8000,https://hwytms.com,https://www.hwytms.com

# CoDriver runtime
CODRIVER_STORAGE_DIR=/data/codriver
CODRIVER_HOST=0.0.0.0
CODRIVER_PORT=8010

# Ollama local model config; can point to a WireGuard-accessible host.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=5
WIREGUARD_OLLAMA_HOSTS=

# Cloudflare dev DNS. Generate CLOUDFLARE_API_TOKEN locally from vault/env if present.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CF_DEV_TARGET=
CF_DEV_RECORDS=dev.hwydriver.com,dev.hwytms.com,dev.hwytrucking.com,codriver-dev.hwytrucking.com
