FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev && \
    rm -rf /var/lib/apt/lists/*

COPY backend/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt httpx

COPY codriver ./codriver

EXPOSE 8010

CMD ["uvicorn", "codriver.api:app", "--host", "0.0.0.0", "--port", "8010", "--reload"]
